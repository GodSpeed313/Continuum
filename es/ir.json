{
  "domain": "es_governance",
  "audit_interval": {
    "value": 1.0,
    "unit": "hour"
  },
  "tiebreaker": "timestamp_asc",
  "entities": {
    "ElasticsearchIndex": {
      "schema_intact": "boolean",
      "replica_health": "text",
      "shards_synced": "boolean",
      "index_name": "identifier"
    }
  },
  "constraints": {
    "SchemaIntegrity": {
      "priority": "critical",
      "rule": {
        "kind": "equality_rule",
        "ref": "ElasticsearchIndex.schema_intact",
        "value": true
      },
      "on_violation": [
        "freeze",
        "escalate"
      ],
      "escalation": [],
      "decay_check": {
        "value": 1.0,
        "unit": "hour"
      }
    },
    "ReplicaHealth": {
      "priority": "high",
      "rule": {
        "kind": "membership_rule",
        "ref": "ElasticsearchIndex.replica_health"
      },
      "on_violation": [
        "escalate"
      ],
      "escalation": [],
      "decay_check": {
        "value": 30.0,
        "unit": "minutes"
      }
    },
    "ShardSync": {
      "priority": "high",
      "rule": {
        "kind": "equality_rule",
        "ref": "ElasticsearchIndex.shards_synced",
        "value": true
      },
      "on_violation": [
        "flag",
        "escalate"
      ],
      "escalation": [],
      "decay_check": {
        "value": 15.0,
        "unit": "minutes"
      }
    }
  },
  "maps": {
    "ElasticsearchIndex.replica_health": [
      {
        "maps_to": "healthy",
        "triggers": [
          "green"
        ]
      },
      {
        "maps_to": "degraded",
        "triggers": [
          "yellow",
          "red"
        ]
      }
    ]
  },
  "enforce": {
    "ElasticsearchIndex": [
      "SchemaIntegrity",
      "ReplicaHealth",
      "ShardSync"
    ]
  },
  "arbiter": {
    "name": "ESArbiter",
    "acceptable_evolution": [
      "index_alias_change",
      "replica_count_tuning"
    ],
    "never_acceptable": [
      "mapping_field_removal",
      "field_type_change",
      "constraint_removal"
    ],
    "requires_human_review": [
      "new_field_addition",
      "analyzer_change",
      "index_settings_change"
    ],
    "acceptance_monitor": {
      "threshold": 0.9,
      "window": {
        "value": 30.0,
        "unit": "days"
      }
    }
  }
}